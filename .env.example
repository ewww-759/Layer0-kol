# Threads Authentication Cookie
# ===========================
# This is REQUIRED for Layer 1 (Seed Discovery) to work, because Meta now completely blocks guest (unauthenticated) searches.
# How to get your cookie:
# 1. Log into https://www.threads.net
# 2. Press F12 to open Developer Tools -> Network
# 3. Refresh the page and click on any network request (e.g., graphql)
# 4. Find the "cookie:" field in the Request Headers
# 5. Copy the entire cookie string and paste it below (do not add line breaks)

THREADS_COOKIE="your_actual_cookie_string_here"

# LLM API Keys (set the one matching your backend in config/llm_config.yaml)
# --------------------------------------------------------------------------
OPENAI_API_KEY=""
GEMINI_API_KEY=""
